# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- LLM provider ---
# One of: gemini | openai | anthropic | deepseek
LLM_PROVIDER=gemini
LLM_API_KEY=AIzaSyA0NZDsmWG6YN7hE0DIE9tJRa_5MLDZ2-c
LLM_MODEL=gemini-2.5-pro

# --- Database ---
DATABASE_URL=postgresql+asyncpg://researchflow:researchflow@localhost:5432/researchflow

# --- Vector DB ---
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_PROVIDER=chroma

# --- Firebase Auth ---
FIREBASE_PROJECT_ID=your-firebase-project
# Either provide a path to the service-account JSON...
FIREBASE_CREDENTIALS_PATH=
# ...or paste the JSON contents directly (single-line, JSON-escaped).
FIREBASE_CREDENTIALS_JSON=

# --- Dev-only bypass (never enable in staging/prod) ---
DEV_AUTH_BYPASS=true

# --- Discovery ---
# Optional: raises Semantic Scholar rate limits
SEMANTIC_SCHOLAR_API_KEY=

# --- Limits ---
DEFAULT_TOKEN_CAP_USD=5.0
MAX_PAPER_CANDIDATES=30
TOKEN_CAP_WARN_PCT=0.8
